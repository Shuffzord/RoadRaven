{
	"name": "@roadraven/plugin-claude-code",
	"version": "0.5.0",
	"private": false,
	"type": "module",
	"description": "MCP wrapper that lets Claude Code (and any MCP host) push live node status updates to a running RoadRaven desktop app via its WebSocket Event API.",
	"keywords": [
		"mcp",
		"claude-code",
		"roadraven",
		"roadmap",
		"event-api"
	],
	"bin": {
		"roadraven-mcp": "./dist/index.js"
	},
	"main": "./dist/index.js",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun build src/index.ts --outdir dist --target node",
		"prepublishOnly": "bun run build",
		"test": "vitest run"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^22",
		"typescript": "^5",
		"vitest": "^4.1.4"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Shuffzord/RoadRaven.git",
		"directory": "plugins/claude-code"
	},
	"license": "PolyForm-Noncommercial-1.0.0",
	"homepage": "https://shuffzord.github.io/RoadRaven/plugin-authoring.html",
	"bugs": "https://github.com/Shuffzord/RoadRaven/issues"
}
