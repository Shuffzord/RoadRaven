{
  "name": "roadraven-workspace",
  "private": true,
  "workspaces": [
    "packages/*",
    "plugins/*"
  ],
  "scripts": {
    "dev:hmr": "bun run --cwd packages/desktop dev:hmr",
    "build:canary": "bun run --cwd packages/desktop build:canary",
    "start": "bun run --cwd packages/desktop start",
    "dev": "bun run --cwd packages/desktop dev",
    "test": "bun run --filter '*' test",
    "test:desktop": "bun run --cwd packages/desktop test",
    "test:file": "bun run --cwd packages/desktop test:file",
    "test:typecheck": "bun run --cwd packages/desktop typecheck",
    "test:build": "bun run --cwd packages/desktop build",
    "test:lint": "bunx @biomejs/biome lint packages/desktop/src/ shared/",
    "verify": "bun run test && bun run test:typecheck && bun run test:build && bun run test:lint",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "dependencies": {
    "rehype-sanitize": "^6.0.0"
  },
  "lint-staged": {
    "{packages,shared,plugins}/**/*.{ts,tsx,js,jsx,json,css}": "bunx @biomejs/biome check --write --diagnostic-level=error"
  }
}
