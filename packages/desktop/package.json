{
	"name": "@roadraven/desktop",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run dev:bun\"",
		"dev:bun": "electrobun dev",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary",
		"icons": "bun run scripts/build-icons.ts",
		"build:stable": "vite build && electrobun build --env=stable",
		"test": "vitest run",
		"test:bun": "bun test tests/unit/bun/eventServer.test.ts tests/unit/bun/eventServer.eaddrinuse.test.ts tests/integration/eventApi.test.ts tests/integration/eventApi-e2e.test.ts",
		"test:file": "vitest run",
		"test:e2e": "playwright test",
		"test:release": "cd ../.. && vitest run tests/release/",
		"test:a11y": "playwright test --config=tests/a11y/playwright.config.ts",
		"typecheck": "tsc --noEmit",
		"build": "vite build"
	},
	"dependencies": {
		"@codemirror/autocomplete": "^6.20.1",
		"@codemirror/commands": "^6.10.3",
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/language": "^6.12.3",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.41.0",
		"@logtape/logtape": "^2.0.5",
		"@radix-ui/react-context-menu": "^2.2.16",
		"@radix-ui/react-dialog": "^1.1.15",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/react-virtual": "3.13.24",
		"electrobun": "1.18.1",
		"react": "^19.2.5",
		"react-d3-tree": "^3.6.6",
		"react-dom": "^19.2.5",
		"rehype-react": "^8.0.0",
		"remark": "^15.0.1",
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.1.2",
		"unified": "^11.0.5",
		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.11",
		"@playwright/test": "^1.59.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/bun": "latest",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/three": "^0.183.1",
		"@vitejs/plugin-react": "^4.3.4",
		"concurrently": "^9.1.0",
		"jsdom": "^29.0.2",
		"png-to-ico": "^3.0.1",
		"postcss": "^8.4.49",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^6.0.3",
		"vitest": "^4.1.4"
	}
}
